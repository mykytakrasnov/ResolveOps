# Local PostgreSQL
POSTGRES_DB=resolveops
POSTGRES_USER=resolveops
POSTGRES_PASSWORD=resolveops
POSTGRES_PORT=5432
DATABASE_URL_POOLED=postgresql+psycopg://resolveops:resolveops@localhost:5432/resolveops
DATABASE_URL_DIRECT=postgresql+psycopg://resolveops:resolveops@localhost:5432/resolveops

# Local MinIO (S3-compatible R2 substitute)
MINIO_ROOT_USER=resolveops
MINIO_ROOT_PASSWORD=resolveops-local-secret
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET=resolveops-local
R2_ENDPOINT=http://localhost:9000
R2_BUCKET=resolveops-local
R2_ACCESS_KEY_ID=resolveops
R2_SECRET_ACCESS_KEY=resolveops-local-secret
