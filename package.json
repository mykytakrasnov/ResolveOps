{
  "name": "resolveops",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.0.7",
  "engines": {
    "node": "22.22.3",
    "pnpm": "11.0.7"
  },
  "scripts": {
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome lint .",
    "typecheck": "pnpm --recursive --if-present typecheck",
    "check": "pnpm format:check && pnpm lint && pnpm typecheck"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.13",
    "typescript": "5.9.3"
  }
}
